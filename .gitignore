*.DS_Store
*.LSOverride
Thumbs.db
.bundle
node_modules/

# rulesync が生成する cache。bun run rulesync:skills で再生成可能
.rulesync/skills/.curated/
# claude 用隔離パイプラインの cache (rulesync-claude/rulesync.lock は追跡する)
rulesync-claude/.rulesync/

# Claude Code: セッション単位の一時ファイル
.claude/plans/
.claude/worktrees/
.claude/settings.local.json
.claude/*.local.md
# pr-monitor skill の監視状態ファイル (ローカル固有、リポを汚さない前提のパス)
.claude/.pr-monitor/

# Claude Code プラグインの自動ダウンロード実体 (node_modules 相当)。
# ただし .agents/skills/ は rulesync が生成する Codex 用 skill (コミット対象) なので除外しない
.agents/*
!.agents/skills/

# Serena MCP server プロジェクト状態 (ローカル固有)
.serena/

# test-mutation-gate skill のローカルフォールバック出力。
# LOOP_OPS_TOKEN / gh 送信が無い環境で .cache/test-mutation-gate/ に落ちるため、
# 未追跡ファイルで worktree を汚さないよう ignore する。
.cache/


# APM dependencies
apm_modules/
