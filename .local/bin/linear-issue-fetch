#!/usr/bin/env bash
# linear-issue-fetch: Linear GraphQL API から「Claude Code に対応させたい未着手 issue」を JSON 配列で出力する。
#
# 対象 issue の条件:
#   - label に "claude:ready" を含む
#   - label に "claude:in-progress" / "claude:done" / "claude:failed" を含まない
#   - state.type が "backlog" または "unstarted"
#
# 必須環境変数:
#   LINEAR_API_KEY  Linear Personal API Key (Settings → API)
# 任意環境変数:
#   LINEAR_TEAM_KEY 特定チームのみに絞り込む場合の team key (例: ENG)
#
# 出力 (stdout): issue オブジェクトの JSON 配列。
# 失敗時は stderr にエラーを出して非0終了。

set -euo pipefail

: "${LINEAR_API_KEY:?LINEAR_API_KEY is required}"

LINEAR_TEAM_KEY="${LINEAR_TEAM_KEY:-}"

read -r -d '' QUERY <<'GRAPHQL' || true
query ClaudeReadyIssues($filter: IssueFilter) {
  issues(filter: $filter, first: 50, orderBy: createdAt) {
    nodes {
      id
      identifier
      title
      description
      url
      branchName
      state { name type }
      team { key }
      labels { nodes { id name } }
    }
  }
}
GRAPHQL

FILTER_JSON=$(jq -n \
  --arg team "$LINEAR_TEAM_KEY" \
  '{
    state: { type: { in: ["backlog", "unstarted"] } },
    labels: { some: { name: { eq: "claude:ready" } } },
    and: [
      { labels: { every: { name: { neq: "claude:in-progress" } } } },
      { labels: { every: { name: { neq: "claude:done" } } } },
      { labels: { every: { name: { neq: "claude:failed" } } } }
    ]
  } + (if $team == "" then {} else { team: { key: { eq: $team } } } end)')

PAYLOAD=$(jq -n --arg q "$QUERY" --argjson v "{\"filter\": $FILTER_JSON}" \
  '{query: $q, variables: $v}')

RESPONSE=$(curl --fail-with-body --silent --show-error \
  -X POST https://api.linear.app/graphql \
  -H "Authorization: $LINEAR_API_KEY" \
  -H "Content-Type: application/json" \
  --data "$PAYLOAD")

if echo "$RESPONSE" | jq -e '.errors' >/dev/null 2>&1; then
  echo "linear-issue-fetch: GraphQL error" >&2
  echo "$RESPONSE" | jq '.errors' >&2
  exit 1
fi

echo "$RESPONSE" | jq '.data.issues.nodes'
