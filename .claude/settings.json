  "statusLine": {
    "type": "command",
    "command": "bash /Users/kanade0404/.claude/statusline-command.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ENV_BEFORE=$(export -p | sort); source ~/.zshrc 2>/dev/null; if [ -n \"$CLAUDE_ENV_FILE\" ]; then ENV_AFTER=$(export -p | sort); comm -13 <(echo \"$ENV_BEFORE\") <(echo \"$ENV_AFTER\") >> \"$CLAUDE_ENV_FILE\"; fi; exit 0'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"git commit.*(--no-verify|\\\\s-n(\\\\s|$))\")) or (.tool_input.command | test(\"git merge.*--no-verify\")) then {\"decision\": \"block\", \"reason\": \"エラー: --no-verifyフラグの使用は禁止されています。git hooksを無効化することはできません。\"} elif (.tool_input.command | test(\"git push.*(--force|\\\\s-f(\\\\s|$)|--force-with-lease|--force-if-includes|--delete|\\\\s-d(\\\\s|$)|\\\\s\\\\+\\\\S)\")) then {\"decision\": \"block\", \"reason\": \"エラー: force push、リモートブランチ削除、+refspec構文は禁止されています。\"} elif (.tool_input.command | test(\"git add \\\\.$|git add \\\\. \")) then {\"decision\": \"block\", \"reason\": \"エラー: git add . は禁止されています。ファイルを個別に指定してください。\"} else empty end'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "figma": {
      "type": "http",
