# Codex execpolicy rules.
#
# Claude Code の `.claude/settings.json` にある Bash permissions と同じ意図を
# Codex の prefix_rule へ写したもの。Codex では allow/ask/deny ではなく
# allow/prompt/forbidden を使う。

prefix_rule(pattern = ["pwd"], decision = "allow", justification = "Print current directory.")
prefix_rule(pattern = ["true"], decision = "allow", justification = "No-op success command.")
prefix_rule(pattern = ["false"], decision = "allow", justification = "No-op failure command.")
prefix_rule(pattern = ["date"], decision = "allow", justification = "Read the current date/time.")
prefix_rule(pattern = ["echo"], decision = "allow", justification = "Print literal output.")
prefix_rule(pattern = ["printf"], decision = "allow", justification = "Print literal output.")
prefix_rule(pattern = ["jq"], decision = "allow", justification = "Inspect and transform JSON.")
prefix_rule(pattern = ["readlink"], decision = "allow", justification = "Inspect symlink targets.")
prefix_rule(pattern = ["head"], decision = "allow", justification = "Inspect file prefixes.")
prefix_rule(pattern = ["tail"], decision = "allow", justification = "Inspect file suffixes.")
prefix_rule(pattern = ["wc"], decision = "allow", justification = "Count file or stream content.")
prefix_rule(pattern = ["sort"], decision = "allow", justification = "Sort inspected text.")
prefix_rule(pattern = ["tr"], decision = "allow", justification = "Transform inspected text.")
prefix_rule(pattern = ["cut"], decision = "allow", justification = "Select inspected text fields.")
prefix_rule(pattern = ["uniq"], decision = "allow", justification = "Collapse repeated inspected lines.")
prefix_rule(pattern = ["diff"], decision = "allow", justification = "Compare files.")
prefix_rule(pattern = ["od"], decision = "allow", justification = "Inspect binary data.")
prefix_rule(pattern = ["command"], decision = "allow", justification = "Inspect command availability.")
prefix_rule(pattern = ["grep"], decision = "allow", justification = "Inspect text when rg is not suitable.")
prefix_rule(pattern = ["mkdir"], decision = "allow", justification = "Create directories.")

prefix_rule(pattern = ["git", "status"], decision = "allow", justification = "Inspect repository state.")
prefix_rule(pattern = ["git", "diff"], decision = "allow", justification = "Inspect repository changes.")
prefix_rule(pattern = ["git", "log"], decision = "allow", justification = "Inspect commit history.")
prefix_rule(pattern = ["git", "branch"], decision = "allow", justification = "Inspect branches.")
prefix_rule(pattern = ["git", "show"], decision = "allow", justification = "Inspect git objects.")
prefix_rule(pattern = ["git", "stash", "list"], decision = "allow", justification = "Inspect stash entries.")
prefix_rule(pattern = ["git", "rev-parse"], decision = "allow", justification = "Resolve git refs.")
prefix_rule(pattern = ["git", "diff-tree"], decision = "allow", justification = "Inspect commit file changes.")
prefix_rule(pattern = ["git", "remote"], decision = "allow", justification = "Inspect git remotes.")
prefix_rule(pattern = ["git", "tag"], decision = "allow", justification = "Inspect tags.")
prefix_rule(pattern = ["git", "ls-files"], decision = "allow", justification = "Inspect tracked files.")
prefix_rule(pattern = ["git", "ls-remote"], decision = "allow", justification = "Inspect remote refs.")

prefix_rule(pattern = ["git", "add", "-A"], decision = "forbidden", justification = "Broad staging should be done explicitly by the user.")
prefix_rule(pattern = ["git", "add", "--all"], decision = "forbidden", justification = "Broad staging should be done explicitly by the user.")
prefix_rule(pattern = ["git", "add", "-u"], decision = "forbidden", justification = "Broad update staging should be done explicitly by the user.")
prefix_rule(pattern = ["git", "add", "--update"], decision = "forbidden", justification = "Broad update staging should be done explicitly by the user.")
prefix_rule(pattern = ["git", "add"], decision = "prompt", justification = "Staging changes should stay explicit.")
prefix_rule(pattern = ["git", "commit"], decision = "forbidden", justification = "Commit flags such as --no-verify cannot be denied position-independently with prefix rules.")
prefix_rule(pattern = ["git", "push"], decision = "forbidden", justification = "Push flags such as --force and --delete cannot be denied position-independently with prefix rules.")
prefix_rule(pattern = ["git", "stash"], decision = "prompt", justification = "Changing working tree state should stay explicit.")
prefix_rule(pattern = ["git", "switch"], decision = "prompt", justification = "Changing branches should stay explicit.")
prefix_rule(pattern = ["git", "fetch"], decision = "prompt", justification = "Network git operations should stay explicit.")
prefix_rule(pattern = ["git", "pull"], decision = "prompt", justification = "Merging remote changes should stay explicit.")
prefix_rule(pattern = ["git", "merge"], decision = "forbidden", justification = "Merge flags such as --no-verify cannot be denied position-independently with prefix rules.")
prefix_rule(pattern = ["git", "worktree"], decision = "prompt", justification = "Creating or changing worktrees should stay explicit.")
prefix_rule(pattern = ["git", "cherry-pick"], decision = "prompt", justification = "History-changing operations should stay explicit.")
prefix_rule(pattern = ["git", "revert"], decision = "prompt", justification = "History-changing operations should stay explicit.")
prefix_rule(pattern = ["git", "restore"], decision = "prompt", justification = "Restoring files can discard work.")
prefix_rule(pattern = ["git", "rm"], decision = "prompt", justification = "Removing tracked files should stay explicit.")
prefix_rule(pattern = ["git", "clean"], decision = "forbidden", justification = "Use an explicit user-approved cleanup plan instead.")
prefix_rule(pattern = ["git", "reset"], decision = "forbidden", justification = "Use safer non-destructive git operations instead.")
prefix_rule(pattern = ["git", "rebase"], decision = "forbidden", justification = "Rewriting history needs a direct user request.")
prefix_rule(pattern = ["git", "checkout"], decision = "forbidden", justification = "Use git switch/restore with explicit approval instead.")
prefix_rule(pattern = ["git", "-C"], decision = "forbidden", justification = "Run git from the intended working directory instead of bypassing cwd checks.")
prefix_rule(pattern = ["git", "--git-dir"], decision = "forbidden", justification = "Do not bypass repository path checks.")
prefix_rule(pattern = ["git", "--work-tree"], decision = "forbidden", justification = "Do not bypass repository path checks.")

prefix_rule(pattern = ["gh", "pr"], decision = "prompt", justification = "PR operations can read or mutate remote state.")
prefix_rule(pattern = ["gh", "issue"], decision = "prompt", justification = "Issue operations can read or mutate remote state.")
prefix_rule(pattern = ["gh", "run", "view"], decision = "allow", justification = "Inspect GitHub Actions logs.")
prefix_rule(pattern = ["gh", "api"], decision = "prompt", justification = "GitHub API calls may mutate remote state.")
prefix_rule(pattern = ["gh", "repo", "view"], decision = "allow", justification = "Inspect repository metadata.")
prefix_rule(pattern = ["gh", "auth", "status"], decision = "forbidden", justification = "Auth status can expose tokens, and token flags cannot be denied position-independently with prefix rules.")

prefix_rule(pattern = ["gh", "auth", "login"], decision = "forbidden", justification = "Authentication changes should be done by the user.")
prefix_rule(pattern = ["gh", "auth", "logout"], decision = "forbidden", justification = "Authentication changes should be done by the user.")
prefix_rule(pattern = ["gh", "auth", "refresh"], decision = "forbidden", justification = "Authentication changes should be done by the user.")
prefix_rule(pattern = ["gh", "auth", "switch"], decision = "forbidden", justification = "Authentication changes should be done by the user.")
prefix_rule(pattern = ["gh", "auth", "setup-git"], decision = "forbidden", justification = "Authentication changes should be done by the user.")
prefix_rule(pattern = ["gh", "auth", "token"], decision = "forbidden", justification = "Do not expose auth tokens.")
prefix_rule(pattern = ["gh", "auth", "git-credential"], decision = "forbidden", justification = "Do not expose auth credentials.")
prefix_rule(pattern = ["gh", "ssh-key"], decision = "forbidden", justification = "SSH key management should be done by the user.")
prefix_rule(pattern = ["gh", "gpg-key"], decision = "forbidden", justification = "GPG key management should be done by the user.")
prefix_rule(pattern = ["gh", "secret"], decision = "forbidden", justification = "Secret management should be done by the user.")
prefix_rule(pattern = ["gh", "variable"], decision = "forbidden", justification = "Repository variable changes should be done by the user.")
prefix_rule(pattern = ["gh", "config"], decision = "forbidden", justification = "GitHub CLI configuration should be done by the user.")
prefix_rule(pattern = ["gh", "repo", "delete"], decision = "forbidden", justification = "Repository deletion is destructive.")
prefix_rule(pattern = ["gh", "repo", "create"], decision = "forbidden", justification = "Repository creation should be explicitly requested.")
prefix_rule(pattern = ["gh", "run", "cancel"], decision = "forbidden", justification = "CI cancellation should be explicitly requested.")
prefix_rule(pattern = ["gh", "run", "delete"], decision = "forbidden", justification = "CI run deletion is destructive.")
prefix_rule(pattern = ["gh", "run", "rerun"], decision = "forbidden", justification = "CI reruns should be explicitly requested.")
prefix_rule(pattern = ["gh", "pr", "close"], decision = "forbidden", justification = "Closing PRs should be explicitly requested.")
prefix_rule(pattern = ["gh", "pr", "merge"], decision = "forbidden", justification = "Merging PRs should be explicitly requested.")

prefix_rule(pattern = ["bun", "test"], decision = "allow", justification = "Run test suite.")
prefix_rule(pattern = ["make"], decision = "prompt", justification = "Make targets may mutate files or run external tools.")
prefix_rule(pattern = ["shellcheck"], decision = "allow", justification = "Run shell lint checks.")

prefix_rule(pattern = ["uv", "version"], decision = "allow", justification = "Inspect uv version.")
prefix_rule(pattern = ["uv", "tree"], decision = "allow", justification = "Inspect dependency tree.")
prefix_rule(pattern = ["uv", "pip", "list"], decision = "allow", justification = "Inspect installed Python packages.")
prefix_rule(pattern = ["uv", "pip", "show"], decision = "allow", justification = "Inspect a Python package.")
prefix_rule(pattern = ["uv", "python", "list"], decision = "allow", justification = "Inspect available Python versions.")
prefix_rule(pattern = ["uv", "run", "pytest"], decision = "allow", justification = "Run Python tests.")
prefix_rule(pattern = ["uv", "run", "--all-packages", "pytest"], decision = "allow", justification = "Run Python tests for all packages.")
prefix_rule(pattern = ["uv", "run", "pyright"], decision = "allow", justification = "Run Python type checks.")
prefix_rule(pattern = ["uv", "run", "ruff", "check"], decision = "allow", justification = "Run Python lint checks.")
prefix_rule(pattern = ["uv", "run", "ruff", "format", "--check"], decision = "allow", justification = "Check Python formatting.")
prefix_rule(pattern = ["uv", "run", "lint-imports"], decision = "allow", justification = "Run import boundary checks.")
prefix_rule(pattern = ["uv", "run", "ast-grep", "scan"], decision = "allow", justification = "Run structural code scans.")
prefix_rule(pattern = ["uv", "sync"], decision = "allow", justification = "Sync project dependencies.")
prefix_rule(pattern = ["uv", "lock"], decision = "allow", justification = "Update or validate uv lockfile.")
prefix_rule(pattern = ["uv", "add"], decision = "prompt", justification = "Dependency additions should stay explicit.")
prefix_rule(pattern = ["uv", "remove"], decision = "prompt", justification = "Dependency removals should stay explicit.")
prefix_rule(pattern = ["uv", "pip", "install"], decision = "prompt", justification = "Package installs should stay explicit.")
prefix_rule(pattern = ["uv", "pip", "uninstall"], decision = "prompt", justification = "Package removals should stay explicit.")
prefix_rule(pattern = ["uv", "python", "install"], decision = "prompt", justification = "Runtime installs should stay explicit.")
prefix_rule(pattern = ["uv", "init"], decision = "prompt", justification = "Project initialization should stay explicit.")

prefix_rule(pattern = ["lefthook"], decision = "allow", justification = "Run configured repository checks.")
prefix_rule(pattern = ["adr"], decision = "allow", justification = "Manage ADR records.")
prefix_rule(pattern = ["atlas", "migrate"], decision = "allow", justification = "Run Atlas migration commands.")
prefix_rule(pattern = ["psql", "--version"], decision = "allow", justification = "Inspect psql version.")
prefix_rule(pattern = ["psql"], decision = "prompt", justification = "Database access should stay explicit.")

prefix_rule(pattern = ["nix", "build"], decision = "prompt", justification = "Nix builds may run long and fetch dependencies.")
prefix_rule(pattern = ["nix", "eval"], decision = "allow", justification = "Evaluate Nix expressions.")
prefix_rule(pattern = ["nix", "flake"], decision = "allow", justification = "Inspect or update Nix flake metadata.")
prefix_rule(pattern = ["nix", "search"], decision = "allow", justification = "Search Nix packages.")
prefix_rule(pattern = ["nix", "profile"], decision = "prompt", justification = "Profile changes should stay explicit.")
prefix_rule(pattern = ["nix", "store"], decision = "prompt", justification = "Nix store changes should stay explicit.")
prefix_rule(pattern = ["nix", "path-info"], decision = "allow", justification = "Inspect Nix store paths.")
prefix_rule(pattern = ["nix", "show-derivation"], decision = "allow", justification = "Inspect derivations.")
prefix_rule(pattern = ["nix", "develop", "--command", "adr"], decision = "allow", justification = "Fallback to devShell-provided adr.")
prefix_rule(pattern = ["nix", "develop", "--command", "atlas", "migrate"], decision = "allow", justification = "Fallback to devShell-provided atlas migrate.")
prefix_rule(pattern = ["nix", "develop", "--command", "lefthook"], decision = "allow", justification = "Fallback to devShell-provided lefthook.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "version"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "tree"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "pip", "list"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "pip", "show"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "python", "list"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "pytest"], decision = "allow", justification = "Fallback to devShell-provided pytest.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "--all-packages", "pytest"], decision = "allow", justification = "Fallback to devShell-provided pytest.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "pyright"], decision = "allow", justification = "Fallback to devShell-provided pyright.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "ruff", "check"], decision = "allow", justification = "Fallback to devShell-provided ruff.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "ruff", "format", "--check"], decision = "allow", justification = "Fallback to devShell-provided ruff.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "lint-imports"], decision = "allow", justification = "Fallback to devShell-provided import checks.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "run", "ast-grep", "scan"], decision = "allow", justification = "Fallback to devShell-provided ast-grep.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "sync"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "lock"], decision = "allow", justification = "Fallback to devShell-provided uv.")
prefix_rule(pattern = ["nix", "develop", "--command", "psql", "--version"], decision = "allow", justification = "Fallback to devShell-provided psql.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "add"], decision = "prompt", justification = "Dependency additions should stay explicit.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "remove"], decision = "prompt", justification = "Dependency removals should stay explicit.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "pip", "install"], decision = "prompt", justification = "Package installs should stay explicit.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "pip", "uninstall"], decision = "prompt", justification = "Package removals should stay explicit.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "python", "install"], decision = "prompt", justification = "Runtime installs should stay explicit.")
prefix_rule(pattern = ["nix", "develop", "--command", "uv", "init"], decision = "prompt", justification = "Project initialization should stay explicit.")
prefix_rule(pattern = ["nix", "develop", "--command", "psql"], decision = "prompt", justification = "Database access should stay explicit.")

prefix_rule(pattern = ["nix-env", "--version"], decision = "allow", justification = "Inspect nix-env version.")
prefix_rule(pattern = ["nix-env", "-q"], decision = "allow", justification = "Inspect Nix environment packages.")
prefix_rule(pattern = ["nix-env", "--query"], decision = "allow", justification = "Inspect Nix environment packages.")
prefix_rule(pattern = ["nix-env", "-qa"], decision = "allow", justification = "Search Nix environment packages.")
prefix_rule(pattern = ["darwin-rebuild"], decision = "prompt", justification = "System rebuilds should stay explicit.")

prefix_rule(pattern = ["docker", "ps"], decision = "allow", justification = "Inspect running containers.")
prefix_rule(pattern = ["docker", "images"], decision = "allow", justification = "Inspect local images.")
prefix_rule(pattern = ["docker", "logs"], decision = "allow", justification = "Inspect container logs.")
prefix_rule(pattern = ["docker", "inspect"], decision = "allow", justification = "Inspect Docker metadata.")
prefix_rule(pattern = ["docker", "build"], decision = "prompt", justification = "Docker builds may run long and fetch dependencies.")
prefix_rule(pattern = ["docker", "compose"], decision = "prompt", justification = "Compose commands may mutate containers and volumes.")

prefix_rule(pattern = ["sudo"], decision = "forbidden", justification = "Privilege escalation must be performed directly by the user.")
prefix_rule(pattern = ["bash", "-c"], decision = "forbidden", justification = "Nested shell execution can bypass command-specific policy checks.")
prefix_rule(pattern = ["bash", "-lc"], decision = "forbidden", justification = "Nested login shell execution can bypass command-specific policy checks.")
prefix_rule(pattern = ["nix-shell"], decision = "forbidden", justification = "Ad-hoc nix-shell environments can bypass command-specific policy checks.")
prefix_rule(pattern = ["rm"], decision = "forbidden", justification = "File deletion should be performed through explicit, reviewed edits.")
prefix_rule(pattern = ["ls"], decision = "forbidden", justification = "Use structured file listing tools instead of ad-hoc shell listing.")
prefix_rule(pattern = ["cat"], decision = "forbidden", justification = "Use structured file reading tools instead of ad-hoc shell reads.")
prefix_rule(pattern = ["find"], decision = "forbidden", justification = "Use structured file search tools instead of ad-hoc shell searches.")
prefix_rule(pattern = ["awk"], decision = "forbidden", justification = "Use structured text processing tools instead of ad-hoc awk scripts.")
prefix_rule(pattern = ["sed"], decision = "forbidden", justification = "Use structured editing tools instead of ad-hoc sed scripts.")
prefix_rule(pattern = ["cd"], decision = "forbidden", justification = "Run commands from the intended working directory instead of changing directories.")
prefix_rule(pattern = ["cp"], decision = "forbidden", justification = "Use apply_patch or install scripts instead of ad-hoc copies.")
prefix_rule(pattern = ["mv"], decision = "forbidden", justification = "Use explicit file edits or reviewed rename operations.")
prefix_rule(pattern = ["curl"], decision = "forbidden", justification = "Use reviewed fetch tooling instead of arbitrary downloads.")
prefix_rule(pattern = ["wget"], decision = "forbidden", justification = "Use reviewed fetch tooling instead of arbitrary downloads.")
prefix_rule(pattern = ["nc"], decision = "forbidden", justification = "Raw network connections are not allowed.")
prefix_rule(pattern = ["ssh-add"], decision = "forbidden", justification = "SSH agent changes should be done by the user.")
prefix_rule(pattern = ["ssh-keyscan"], decision = "forbidden", justification = "SSH trust changes should be done by the user.")
prefix_rule(pattern = ["ssh-keygen"], decision = "forbidden", justification = "SSH key generation should be done by the user.")
prefix_rule(pattern = ["printenv"], decision = "forbidden", justification = "Environment dumps may expose secrets.")
prefix_rule(pattern = ["env"], decision = "forbidden", justification = "Environment dumps may expose secrets.")
prefix_rule(pattern = ["export", "-p"], decision = "forbidden", justification = "Environment dumps may expose secrets.")
prefix_rule(pattern = ["set"], decision = "forbidden", justification = "Shell state dumps may expose secrets.")
prefix_rule(pattern = ["compgen"], decision = "forbidden", justification = "Shell completion dumps may expose local environment details.")
prefix_rule(pattern = ["security"], decision = "forbidden", justification = "macOS keychain access is not allowed.")
prefix_rule(pattern = ["gpg", "--export-secret"], decision = "forbidden", justification = "Secret key export is not allowed.")
prefix_rule(pattern = ["npm", "publish"], decision = "forbidden", justification = "Publishing packages should be done by the user.")
prefix_rule(pattern = ["pnpm", "publish"], decision = "forbidden", justification = "Publishing packages should be done by the user.")
prefix_rule(pattern = ["pnpm", "install"], decision = "prompt", justification = "Dependency installs should stay explicit.")
prefix_rule(pattern = ["terraform", "apply"], decision = "forbidden", justification = "Infrastructure mutations require a dedicated approval flow.")
