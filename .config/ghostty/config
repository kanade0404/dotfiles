# Font
font-family = "FiraCode Nerd Font"
font-family = "Hiragino Sans W4"
font-size = 16
font-thicken = true

# Theme (GitHub Light)
background = f6f8fa
foreground = 24292e
cursor-style = block
cursor-color = 0366d6
selection-background = c8e1ff
selection-foreground = 24292e

# Window
window-padding-x = 4
window-padding-y = 4
macos-titlebar-style = tabs
macos-option-as-alt = true
# window-save-state = always
# window-colorspace = "display-p3"

# Keybinds (Cmd only, ctrl delegated to tmux/nvim)
keybind = super+n=new_window
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+enter=toggle_fullscreen
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size
# keybind = ctrl+alt+k=scroll_page_up
# keybind = ctrl+alt+j=scroll_page_down
# keybind = ctrl+alt+u=scroll_half_page_up
# keybind = ctrl+alt+d=scroll_half_page_down

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title
